{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "echo 'Skipping default install step'",
  "buildCommand": "bash ./vercel-build.sh",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ],
  "trailingSlash": false
}
